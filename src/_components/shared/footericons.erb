<div class="max-w-6xl mx-auto px-8 py-8 md:py-16">
  <div class="border-t border-bone pb-8 pt-12 md:pt-24">
    <div class="flex space-x-8 md:space-x-24 justify-center items-center">
      <a href="/">
        <img class="w-24 md:w-8" src="<%= relative_url '/images/icons/home.svg' %>" alt="home icon" />
      </a>
      <% if @icons == true %>
        <a href="callto:+<%= @shop.number_link %>">
          <img class="w-24 md:w-8" src="<%= relative_url '/images/icons/phone.svg' %>" alt="phone icon" />
        </a>
        <a href="<%= @shop.map_link %>">
          <img class="w-24 md:w-8" src="<%= relative_url '/images/icons/map-pin.svg' %>" alt="map-pin icon" />
        </a>
      <% end %>
      <a href="/">
        <img class="w-24 md:w-8" src="<%= relative_url '/images/icons/facebook.svg' %>" alt="facebook icon" />
      </a>
      <a href="/">
        <img class="w-24 md:w-8" src="<%= relative_url '/images/icons/instagram.svg' %>" alt="instagram icon" />
      </a>
      <a href="/">
        <img class="w-24 md:w-8" src="<%= relative_url '/images/icons/youtube.svg' %>" alt="youtube icon" />
      </a>
    </div>
  </div>
</div>
