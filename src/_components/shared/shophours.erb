
<div class="container mx-auto px-2 py-16">
  <h3 class="text-5xl mb-12">Hours</h3>

  <section class="flex justify-between">
    <% @shop.hours.each do |day, time| %>
      <div class="text-center border-r pr-8 last-of-type:border-0">
        <div class="p-2"><%= day.capitalize %></div>
        <div class="p-2 text-4xl"><%= time.upcase %></div>
      </div>
    <% end %>
  </section>
</div>

